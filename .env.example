# Hedera operator (for HCS topic creation + message submission)
# Must be an ECDSA account — see the "Key type matters" note in README.md.
OPERATOR_ACCOUNT_ID=0.0.xxxxxxx
OPERATOR_PRIVATE_KEY=302e0201...

# Created once via CLI (create-session) and then reused — see README.md.
HEDERA_TOPIC_ID=0.0.xxxxxxx

# Hedera JSON-RPC Relay endpoint (Hashio testnet default)
HEDERA_JSON_RPC_URL=https://testnet.hashio.io/api

# EVM account + deployed contract for invoice settlement
EVM_PRIVATE_KEY=0x...
CONTRACT_ADDRESS=0x...

# Optional deployment default (basis points, e.g. 100 = 1%)
DEFAULT_PLATFORM_FEE_BPS=100

# Optional — encrypted local chat storage (defaults to a fixed dev key if unset,
# fine for a PoC, but set your own for anything beyond local demoing)
CHAT_MASTER_KEY=
